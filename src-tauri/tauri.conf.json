{
  "productName": "Belle Beauté POS",
  "version": "1.0.0",
  "identifier": "com.belle.beaute.pos",
  "build": {
    "beforeDevCommand": "npm run web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Belle Beauté POS",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": false,
    "msiInstallerAssets": "./installer/msi",
    "nsisInstallerAssets": "./installer/nsis"
  }
}